#!/bin/bash
# Pre-commit hook: bidirectional sync based on WHICH files changed.
#
# Direction is determined by staged changes, not configuration:
#   commands/ or .claude-plugin/ changed  â†’  CCâ†’Codex
#   .codex-plugin/ changed                â†’  Codexâ†’CC
#   both sides changed                    â†’  warn + use source_of_truth as tiebreaker
#   only skills/ or other shared files    â†’  no conversion needed

REPO_ROOT="$(git rev-parse --show-toplevel)"
CC_TO_CODEX="$REPO_ROOT/plugins/plugin-cross-port/scripts/convert_cc_to_codex.py"
CODEX_TO_CC="$REPO_ROOT/plugins/plugin-cross-port/scripts/convert_codex_to_cc.py"

if [ ! -f "$CC_TO_CODEX" ] || [ ! -f "$CODEX_TO_CC" ]; then
  exit 0
fi

CHANGED_PLUGINS=$(git diff --cached --name-only | grep '^plugins/' | cut -d/ -f1,2 | sort -u)
if [ -z "$CHANGED_PLUGINS" ]; then
  exit 0
fi

get_source_of_truth() {
  local plugin="$1"
  local decision_file="$REPO_ROOT/$plugin/.plugin-cross-port.yaml"
  local sot=""

  if [ -f "$decision_file" ]; then
    sot=$(grep '^source_of_truth:' "$decision_file" | awk '{print $2}' | tr -d "'\"")
  fi

  if [ -z "$sot" ]; then
    local has_cc="$REPO_ROOT/$plugin/.claude-plugin/plugin.json"
    local has_codex="$REPO_ROOT/$plugin/.codex-plugin/plugin.json"
    if [ -f "$has_cc" ] && [ ! -f "$has_codex" ]; then
      sot="claude-code"
    elif [ -f "$has_codex" ] && [ ! -f "$has_cc" ]; then
      sot="codex"
    else
      sot="claude-code"
    fi
  fi

  echo "$sot"
}

run_cc_to_codex() {
  local plugin="$1"
  echo "plugin-cross-port: CCâ†’Codex syncing $plugin"
  python3 "$CC_TO_CODEX" "$plugin" --repo-root "$REPO_ROOT" --force
  local status=$?
  if [ $status -ne 0 ]; then
    echo "âťŚ plugin-cross-port: CCâ†’Codex failed for $plugin. Commit aborted."
    exit 1
  fi
  git add "$REPO_ROOT/$plugin/.codex-plugin/" 2>/dev/null || true
  git add "$REPO_ROOT/$plugin/skills/generated-from-commands/" 2>/dev/null || true
  git add "$REPO_ROOT/$plugin/.plugin-cross-port.yaml" 2>/dev/null || true
  git add "$REPO_ROOT/.agents/plugins/marketplace.json" 2>/dev/null || true
}

run_codex_to_cc() {
  local plugin="$1"
  echo "plugin-cross-port: Codexâ†’CC syncing $plugin"
  python3 "$CODEX_TO_CC" "$plugin" --repo-root "$REPO_ROOT" --force
  local status=$?
  if [ $status -ne 0 ]; then
    echo "âťŚ plugin-cross-port: Codexâ†’CC failed for $plugin. Commit aborted."
    exit 1
  fi
  git add "$REPO_ROOT/$plugin/.claude-plugin/" 2>/dev/null || true
  git add "$REPO_ROOT/$plugin/commands/generated-from-codex-"*.md 2>/dev/null || true
  git add "$REPO_ROOT/$plugin/.plugin-cross-port.yaml" 2>/dev/null || true
}

SYNCED=0

for PLUGIN in $CHANGED_PLUGINS; do
  STAGED=$(git diff --cached --name-only | grep "^$PLUGIN/")

  # CC-exclusive: commands/ and .claude-plugin/ (exclude generated-from-codex)
  CC_CHANGED=$(echo "$STAGED" \
    | grep -E "^$PLUGIN/(commands/[^/]+\.md|\.claude-plugin/)" \
    | grep -v "generated-from-codex")

  # Codex-exclusive: .codex-plugin/
  CODEX_CHANGED=$(echo "$STAGED" | grep "^$PLUGIN/\.codex-plugin/")

  if [ -n "$CC_CHANGED" ] && [ -n "$CODEX_CHANGED" ]; then
    SOT=$(get_source_of_truth "$PLUGIN")
    echo "âš ď¸Ź  plugin-cross-port: both CC and Codex files staged in $PLUGIN â€” using source_of_truth=$SOT"
    if [ "$SOT" = "codex" ]; then
      run_codex_to_cc "$PLUGIN"
    else
      run_cc_to_codex "$PLUGIN"
    fi
    SYNCED=$((SYNCED + 1))
  elif [ -n "$CC_CHANGED" ]; then
    run_cc_to_codex "$PLUGIN"
    SYNCED=$((SYNCED + 1))
  elif [ -n "$CODEX_CHANGED" ]; then
    run_codex_to_cc "$PLUGIN"
    SYNCED=$((SYNCED + 1))
  fi
  # only skills/ or other shared files changed â†’ no conversion needed
done

if [ $SYNCED -gt 0 ]; then
  echo "âś… plugin-cross-port: $SYNCED plugin(s) synced"
fi

exit 0
